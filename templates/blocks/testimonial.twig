{#
  Title: Testimonials
  Description: Testimonials block
  Category: RD-blocks
  Icon: list-view
  Keywords: testimonials
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}

<section class="rd-block rd-spacing rd-testimonial bg-white">
	<div class="rd-container">
    <div class="rd-testimonial-heading">
      {% if fields.title %}
			<h2 class="rd-testimonial-heading__title">{{ fields.title }}</h2>
      {% endif %}
      {% if fields.description %}
        <p class="rd-testimonial-heading__text">{{ fields.description }}</p>
      {% endif %}
    </div>
    {% if fields.shortcode %}
      <div class="rd-testimonial-content">
        {{fn('do_shortcode', fields.shortcode|striptags)}}
      </div>
    {% endif %}
		{% if fields.button %}
			<div class="rd-testimonial-btn">
				<a href="{{ fields.button.url}}" class="btn btn-primary">{{fields.button.title}}</a>
			</div>
		{% endif %}
	</div>
</section>