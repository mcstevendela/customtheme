{#
  Title: About
  Description: About block
  Category: RD-blocks
  Icon: money
  Keywords: format-status
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}

<section class="rd-block rd-spacing rd-media rd-media--about {{ fields.options }}{% if fields.options == 'rd-about--white' %} rd-spacing--white{% endif %}">
  <div class="rd-container rd-media-wrapper">
    <!-- Media -->
    <div class="rd-media-image">
      {% if fields.image %}
        <img src="{{ fields.image.url }}" alt="{{ fields.image.alt }}" class="rd-media__image rd-responsive">
      {% endif %}
    </div>
    <!-- Media End -->
    <!-- Content -->
    <div class="rd-media-content rd-media__align--center">
      {% if fields.subtitle %}
        <span class="rd-tag rd-media__tag">{{ fields.subtitle }}</span>
      {% endif %}
      {% if fields.title %}
        <h2 class="rd-media__title">{{ fields.title }}</h2>
      {% endif %}
      {% if fields.description %}
        <div class="rd-media__text rd-content">{{ fields.description }}</div>
      {% endif %}
      {% if fields.link %}
        <div class="rd-media-btn">
          <a href="{{ fields.link.url }}" target="{{ fields.link.target }}" class="btn btn-primary">{{ fields.link.title }}</a>
        </div>
      {% endif %}
    </div>
    <!-- Content End -->
  </div>
</section>