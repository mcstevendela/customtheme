{#
  Title: Call To Action
  Description: Call To Action Block
  Category: RD-blocks
  Icon: money
  Keywords: cta
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}

<section class="rd-block rd-spacing rd-spacing--white rd-cta">
  <div class="rd-container">
    <div class="rd-cta-wrapper">
      <!-- Content -->
      <div class="rd-cta-content">
        {% if fields.title %}
          <h2 class="rd-cta__title">{{ fields.title }}</h2>
        {% endif %}
        {% if fields.button %}
          <div class="rd-cta-btn">
            <a href="{{ fields.button.url }}" target="{{ fields.button.target }}" class="btn btn-tertiary">{{ fields.button.title }}</a>
          </div>
        {% endif %}
      </div>
      <!-- Content End -->
      <!-- Background Image -->
      <img src="{{ site.theme.link }}/images/cta.jpg" title="Call To Action Background" alt="Call To Action Background" class="rd-cta__bg">
    </div>
  </div>
</section>