          .rd-form-main form {
            BORDER-RIGHT-WIDTH: 2px;
            BACKGROUND-COLOR: #f2a324;
            BORDER-TOP-WIDTH: 2px;
            BORDER-BOTTOM-WIDTH: 2px;
            BORDER-LEFT-WIDTH: 2px;
            -webkit-transform: scale(1);  
            padding: 24px;
            border-radius: 1rem
          }

          .rd-form-main #docContainer .fb-item.fb-50-item-column {
            width: 49%;
            padding: 5px 4px 10px 4px;
            display: inline-block;
          }

          .rd-form-main #docContainer .fb-item.fb-100-item-column {
            width: 100%;
            padding: 5px 4px 10px 4px;
            display: inline-block;
          }

          .rd-form-main #docContainer #column1 {
            display: flex;
            flex-wrap: wrap;
            justify-content: space-between;
          }

          .rd-form-main #docContainer .fb-input-box input,
          .rd-form-main #docContainer .fb-dropdown select,
          .rd-form-main #docContainer .fb-input-date input {
            color: rgb(69, 69, 69);
            border: 1px solid rgb(220, 223, 231);
            border-top-color: rgb(170, 173, 178);
            -webkit-border-radius: 3px;
            -moz-border-radius: 3px;
            border-radius: 3px;
            width: 100%;
            padding: 10px;
          }

          .rd-form-main .fb-textarea textarea {
            width: 100%;
            padding: 10px;
            border-radius: 3px !important;
          }

          .rd-form-main .fb-footer {
            text-align: center;
          }

          .rd-form-main .error {
            color: rgb(255 0 0);
          }
        </style>

