{#
  Title: Form
  Description: Form block
  Category: RD-blocks
  Icon: money
  Keywords: form
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}

<section class="rd-block rd-spacing rd-spacing--light-yellow rd-form">
  <div class="rd-container rd-form-content">
    {% if fields.title %}
      <h2 class="rd-form__title">{{ fields.title }}</h2>
    {% endif %}
    {#}
    {% if fields.shortcode %}
    <div class="rd-form-main">{{fn('do_shortcode', fields.shortcode|striptags)}}</div>
    {% endif %}
    #}

