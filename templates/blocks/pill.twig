{#
  Title: Media + Text
  Description: Media + Text block
  Category: RD-blocks
  Icon: money
  Keywords: mediatext
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}

<section class="rd-block rd-spacing rd-spacing--white rd-media rd-media--pill" style="background: url({{ fields.background.url }}) no-repeat center; background-size: cover;">
  <div class="rd-container rd-media-wrapper {% if fields.image %}rd-media-wrapper--start{% endif %}">
    <!-- Button -->
      {% if fields.button %}
        <div class="rd-media-btn rd-media-btn--out">
          <a class="btn btn-primary" href="{{ fields.button.url }}" target="{{ fields.button.target }}">{{ fields.button.title }}</a>
        </div>
      {% endif %}
    <!-- Button End -->
    <!-- Media -->
    {% if fields.image %}
    <div class="rd-media-image">
      <img src="{{ fields.image.url }}" alt="{{ fields.image.alt }}" class="rd-media__image">
    </div>
    {% endif %}
    <!-- Media End -->
    <!-- Content -->
    <div class="rd-media-content">
      {% if fields.title %}
        <h2 class="rd-media__title">{{ fields.title }}</h2>
      {% endif %}
      {% if fields.pills %}
        <div class="rd-media-pills {% if fields.image %}rd-media-pills--start{% endif %}">
          {% for pill in fields.pills %}
            <a {% if pill.link.url %} href="{{ pill.link.url }}" {% endif %} class="rd-media-pills-item {% if pill.link.url %}rd-media-pills-item--link{% endif %}">
              <img src="{{ fields.icon.url }}" alt="{{ fields.icon.alt }}" class="rd-media-pills__icon injectable">
              {{ pill.link.title }}
            </a>
          {% endfor %}
        </div>
      {% endif %}
      <!-- Button -->
      {% if fields.button %}
        <div class="rd-media-btn rd-media-btn--in">
          <a class="btn btn-primary" href="{{ fields.button.url }}" target="{{ fields.button.target }}">{{ fields.button.title }}</a>
        </div>
      {% endif %}
    <!-- Button End -->
    </div>
    <!-- Content End -->
  </div>
</section>