{#
  Title: FAQs
  Description: FAQs Block
  Category: RD-blocks
  Icon: editor-help
  Keywords: cta
  Mode: edit
  Align: left
  PostTypes: page post
  SupportsAlign: left right
  SupportsMode: true
  SupportsMultiple: true
#}

<section class="rd-block rd-spacing rd-spacing--white rd-media rd-media--faq bg-white">
  <div class="rd-container rd-media-wrapper">
    <!-- Media -->
    <div class="rd-media-image">
      {% if fields.image %}
        <img src="{{ fields.image.url }}" alt="{{ fields.image.alt }}" class="rd-media__image rd-responsive">
      {% endif %}
    </div>
    <!-- Media End -->
    <!-- Content -->
    <div class="rd-media-content">
      {% if fields.title %}
        <h2 class="rd-media__title">{{ fields.title }}</h2>
      {% endif %}
      {% if fields.questions %}
      <div class="rd-media-faq">
        {% for item in fields.questions %}
          <div class="rd-media-faq-item">
            <div class="rd-media-faq-question">
              <span class="rd-media-faq__text">{{ item.question }}</span>
              <div class="rd-media-faq-icon">
                <img src="{{ site.theme.link }}/images/icons/arrow-down-faq.svg" title="Arrow Down" alt="Arrow Down" class="rd-media-faq-icon__arrow injectable">
              </div>
            </div>
            <div class="rd-media-faq-answer rd-content">
              {{ item.answer }}
            </div>
          </div>
        {% endfor %}
      </div>
      {% endif %}
      <!-- Button -->
      {% if fields.button %}
        <div class="rd-media-btn">
          <a href="{{ fields.button.url }}" target="{{ fields.button.target }}" class="btn btn-primary">{{ fields.button.title }}</a>
        </div>
      {% endif %}
      <!-- Button End -->
    </div>
    <!-- Content End -->

  </div>
</section>