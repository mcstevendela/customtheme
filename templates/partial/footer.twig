<footer class="rd-footer">
  <!-- Footer Top -->
  <div class="rd-footer-top">
    <div class="rd-footer-wrapper rd-container">
      <!-- Column 1 -->
      <div class="rd-footer-col rd-footer-col-1">
        <div class="rd-footer-logo">
          <a href="{{ site.link }}">
            <img src="{{ global.footer_logo.url }}" alt="{{ site.title }} - logo" title={{ global.footer_logo.title }}>
          </a>
        </div>
        <div class="rd-footer-description">
          {{ global.footer_description }}
        </div>
        {% if global.footer_license_info %}
        <div class="rd-footer-license">
          <span class="rd-footer-heading">License Info:</span>
          <div class="rd-footer-info">
            {% for item in global.footer_license_info %}
              <span class="rd-footer-info__text">
                {{ item.footer_license }}
              </span>
            {% endfor %}
          </div>
        </div>
        {% endif %}
        {% if global.global_social %}
        <div class="rd-footer-social">
          <span class="rd-footer-heading">Follow Us:</span>
          <div class="rd-footer-social-list">
            {% for item in global.global_social %}
              {% if item.social_link %}
                <a class="rd-footer-social-item__link" href="{{ item.social_link.url }}" target="_blank" aria-label="{{ item.social_link.title }}">
                  {% if item.social_image %}
                    <img src="{{ item.social_image.url }}" alt="{{ item.social_image.title }}" title="{{ item.social_image.title }}">
                  {% endif %}
                </a>
              {% endif %}
            {% endfor %}
          </div>
        </div>
        {% endif %}
      </div>
      <!-- Column 1 End -->
      <!-- Column 2 -->
      <div class="rd-footer-col rd-footer-col-2">
        <span class="rd-footer-heading">Service Areas:</span>
        {% if global.footer_service_area_links %}
        <ul class="rd-footer-menu">
          {% for item in global.footer_service_area_links %}
            <li class="rd-footer-menu-item">
              <a href="{{ item.footer_service_area_link.url }}" class="rd-footer-menu__link">- {{ item.footer_service_area_link.title }} </a>
            </li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
      <!-- Column 2 End -->
      <!-- Column 3 -->
      <div class="rd-footer-col rd-footer-col-3">
        <span class="rd-footer-heading">Our Services:</span>
        {% if global.footer_service_links %}
        <ul class="rd-footer-menu">
          {% for item in global.footer_service_links %}
            <li class="rd-footer-menu-item">
              <a href="{{ item.footer_service_link.url }}" class="rd-footer-menu__link">- {{ item.footer_service_link.title }} </a>
            </li>
          {% endfor %}
        </ul>
        {% endif %}
      </div>
      <!-- Column 3 End -->
    </div>
  </div>
  <!-- Footer Top End -->
  <!-- Footer Bottom -->
  <div class="rd-footer-bottom">
    <div class="rd-footer-bottom-wrapper rd-container">
      <p class="rd-footer-bottom-copy">
        Copyright © {{ "now"|date("Y") }} <span>{{ global.footer_copyright }}</span> | All Rights Reserved
      </p>

      <a href="https://calendly.com/william-3pdelivery615/30min" target="_blank" class="btn btn-full btn-primary rd-footer__btn">Let us help with your next move</a>
    </div>
  </div>
  <!-- Footer Bottom End -->
</footer>

